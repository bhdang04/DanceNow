PORT=5000
NODE_ENV=development

# Supabase (for backend to interact with database)
SUPABASE_URL=#// Note: This is the internal URL for backend usage. Do NOT use the public URL here.
SUPABASE_SERVICE_ROLE_KEY=#// Note: This is the service role key for backend usage. Do NOT use the anon key here.

# CORS
FRONTEND_URL=http://localhost:5173

# Optional: If you want to verify JWT tokens from frontend
SUPABASE_JWT_SECRET=#// Note: This should match the JWT secret used in your Supabase project settings.